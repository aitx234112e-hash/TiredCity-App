<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Header Đỏ (TIREDCITY) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/brand_red"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:srcCompat="@mipmap/ic_logo" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_menu_search" android:layout_marginEnd="16dp" app:tint="@android:color/white"/>
            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/sym_action_email" android:layout_marginEnd="16dp" app:tint="@android:color/white"/>
            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_menu_myplaces" app:tint="@android:color/white"/>
        </LinearLayout>
    </RelativeLayout>

    <!-- Thanh Menu Trắng -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_surface"
        android:elevation="2dp"
        android:paddingTop="12dp"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HOME" android:textSize="10sp" android:textColor="@color/text_secondary" android:layout_marginEnd="16dp" android:paddingBottom="12dp" android:fontFamily="@font/forma_djr_display" android:letterSpacing="0.05"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ABOUT TIREDCITY" android:textSize="10sp" android:textColor="@color/text_secondary" android:layout_marginEnd="16dp" android:paddingBottom="12dp" android:fontFamily="@font/forma_djr_display" android:letterSpacing="0.05"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PRODUCTS" android:textSize="10sp" android:textColor="@color/text_secondary" android:layout_marginEnd="16dp" android:paddingBottom="12dp" android:fontFamily="@font/forma_djr_display" android:letterSpacing="0.05"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="COLLECTIONS" android:textSize="10sp" android:textColor="@color/text_secondary" android:layout_marginEnd="16dp" android:paddingBottom="12dp" android:fontFamily="@font/forma_djr_display" android:letterSpacing="0.05"/>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CONTACT" android:textSize="10sp" android:textColor="@color/brand_red" android:textStyle="bold" android:fontFamily="@font/forma_djr_display" android:letterSpacing="0.05"/>
            <View android:layout_width="match_parent" android:layout_height="2dp" android:background="@color/brand_red" android:layout_marginTop="10dp"/>
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Họa tiết mây trên (Placeholder) -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="start"
                    android:src="@drawable/ic_back"
                    app:tint="@color/brand_red"
                    android:padding="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/contact_customer_care"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/forma_djr_display"
                    android:letterSpacing="0.15" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/contact_title"
                    android:textSize="32sp"
                    android:textColor="@color/brand_red"
                    android:fontFamily="@font/forma_djr_display"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:letterSpacing="-0.02"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/contact_subtitle"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:fontFamily="@font/forma_djr_display"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="24dp"/>

                <!-- Form Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/bg_surface"
                    app:strokeWidth="1dp"
                    app:strokeColor="#F5F5F5">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_name"
                            app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                            app:startIconTint="@color/brand_red"
                            app:startIconPadding="12dp"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:paddingStart="48dp"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_phone_contact"
                            android:layout_marginTop="12dp"
                            app:startIconDrawable="@android:drawable/stat_sys_phone_call"
                            app:startIconTint="@color/brand_red"
                            app:startIconPadding="12dp"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPhone"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:paddingStart="48dp"
                                android:inputType="phone"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_email"
                            android:layout_marginTop="12dp"
                            app:startIconDrawable="@android:drawable/sym_action_email"
                            app:startIconTint="@color/brand_red"
                            app:startIconPadding="12dp"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etEmail"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:paddingStart="48dp"
                                android:inputType="textEmailAddress"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_message_long"
                            android:layout_marginTop="12dp"
                            app:startIconDrawable="@android:drawable/ic_menu_send"
                            app:startIconTint="@color/brand_red"
                            app:startIconPadding="12dp"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etMessage"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:paddingStart="48dp"
                                android:paddingTop="12dp"
                                android:minLines="4"
                                android:gravity="top"
                                android:inputType="textMultiLine"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSendMessage"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="20dp"
                            android:text="@string/btn_send_message"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/forma_djr_display"
                            android:textColor="@android:color/white"
                            android:background="@drawable/bg_button_red_gradient"
                            app:backgroundTint="@null"
                            app:cornerRadius="12dp"
                            android:letterSpacing="0.05"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Store Locator Section (MUJI Style) -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/title_store_locator"
                    android:textSize="22sp"
                    android:textColor="@android:color/black"
                    android:fontFamily="@font/forma_djr_display"
                    android:textStyle="bold"
                    android:layout_marginTop="40dp"
                    android:layout_marginBottom="20dp"
                    android:letterSpacing="0.02"/>

                <!-- Map View Placeholder -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/mapCard"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginBottom="24dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/bg_gradient_dark" /> <!-- Using available drawable as placeholder -->
                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_dialog_map"
                            app:tint="@color/brand_red"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:layout_marginBottom="16dp"
                            android:text="Tap to view all locations on Google Maps"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:fontFamily="@font/forma_djr_display"/>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Store 1 -->
                <LinearLayout
                    android:id="@+id/layoutStore1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="28dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/store_1_name"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@android:color/black"
                        android:fontFamily="@font/forma_djr_display"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="13sp"
                        android:lineSpacingExtra="5dp"
                        android:textColor="#444444"
                        android:fontFamily="@font/forma_djr_display"
                        android:text="@string/store_1_details"/>
                </LinearLayout>

                <!-- Store 2 -->
                <LinearLayout
                    android:id="@+id/layoutStore2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="28dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/store_2_name"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@android:color/black"
                        android:fontFamily="@font/forma_djr_display"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="13sp"
                        android:lineSpacingExtra="5dp"
                        android:textColor="#444444"
                        android:fontFamily="@font/forma_djr_display"
                        android:text="@string/store_2_details"/>
                </LinearLayout>

                <!-- Store 3 -->
                <LinearLayout
                    android:id="@+id/layoutStore3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="28dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/store_3_name"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@android:color/black"
                        android:fontFamily="@font/forma_djr_display"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="13sp"
                        android:lineSpacingExtra="5dp"
                        android:textColor="#444444"
                        android:fontFamily="@font/forma_djr_display"
                        android:text="@string/store_3_details"/>
                </LinearLayout>

                <!-- Store 4 -->
                <LinearLayout
                    android:id="@+id/layoutStore4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="28dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/store_4_name"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@android:color/black"
                        android:fontFamily="@font/forma_djr_display"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="13sp"
                        android:lineSpacingExtra="5dp"
                        android:textColor="#444444"
                        android:fontFamily="@font/forma_djr_display"
                        android:text="@string/store_4_details"/>
                </LinearLayout>

                <!-- Store 5 -->
                <LinearLayout
                    android:id="@+id/layoutStore5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="40dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/store_5_name"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@android:color/black"
                        android:fontFamily="@font/forma_djr_display"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="13sp"
                        android:lineSpacingExtra="5dp"
                        android:textColor="#444444"
                        android:fontFamily="@font/forma_djr_display"
                        android:text="@string/store_5_details"/>
                </LinearLayout>

                <!-- Họa tiết mây dưới (Hidden) -->
                <ImageView
                    android:layout_width="200dp"
                    android:layout_height="100dp"
                    android:layout_gravity="end"
                    android:alpha="0.2"
                    android:src="@android:drawable/ic_menu_report_image"
                    android:visibility="gone"/>

            </LinearLayout>
        </RelativeLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>