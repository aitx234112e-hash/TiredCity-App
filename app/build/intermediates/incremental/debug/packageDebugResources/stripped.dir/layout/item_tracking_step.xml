<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginBottom="4dp">

    <!-- Left: icon + line -->
    <LinearLayout
        android:layout_width="32dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <View
            android:id="@+id/v_step_dot"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:background="@drawable/bg_circle_gold" />

        <View
            android:id="@+id/v_step_line"
            android:layout_width="2dp"
            android:layout_height="32dp"
            android:background="@color/bg_subtle" />
    </LinearLayout>

    <!-- Right: title + description -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tv_step_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đặt hàng thành công"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_step_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="25/05/2026 10:30"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>
</LinearLayout>
