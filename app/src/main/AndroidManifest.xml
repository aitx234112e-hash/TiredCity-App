<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ── Permissions ──────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/ic_menu_gallery"
        android:label="@string/app_name"
        android:roundIcon="@android:drawable/ic_menu_gallery"
        android:supportsRtl="true"
        android:theme="@style/Theme.TiredCity"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- ── Launcher ─────────────────────────────────────────────────── -->
        <activity
            android:name=".ui.onboarding.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.TiredCity.Splash"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── Onboarding & Auth ─────────────────────────────────────────── -->
        <activity
            android:name=".ui.onboarding.OnboardingActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ── Main shell ────────────────────────────────────────────────── -->
        <activity
            android:name=".ui.main.MainActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ── Shop ──────────────────────────────────────────────────────── -->
        <activity
            android:name=".ui.shop.ProductDetailActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.shop.SearchActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.shop.CategoryActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ── Cart & Checkout ───────────────────────────────────────────── -->
        <activity
            android:name=".ui.cart.CartActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.cart.PaymentActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.cart.OrderSuccessActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.cart.OrderTrackingActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ── Profile ───────────────────────────────────────────────────── -->
        <activity
            android:name=".ui.profile.ProfileActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.profile.EditProfileActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.profile.OrderHistoryActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.profile.WardrobeActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ── Styling / AI ──────────────────────────────────────────────── -->
        <activity
            android:name=".ui.styling.AiStylingActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.styling.ChatBotActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

    </application>
</manifest>
