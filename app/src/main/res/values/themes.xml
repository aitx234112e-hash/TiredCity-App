<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TiredCity" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/brand_gold</item>
        <item name="colorOnPrimary">@color/brand_dark</item>
        <item name="colorPrimaryContainer">@color/brand_cream</item>
        <item name="colorOnPrimaryContainer">@color/brand_dark</item>
        <item name="colorSecondary">@color/brand_red</item>
        <item name="colorOnSecondary">@color/bg_surface</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/brand_dark</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Toolbar title text appearance -->
    <style name="TextAppearance.TiredCity.Toolbar" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">17sp</item>
    </style>

    <style name="Theme.TiredCity.Splash" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:colorBackground">@color/brand_dark</item>
        <item name="android:statusBarColor">@color/brand_dark</item>
        <item name="android:navigationBarColor">@color/brand_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
